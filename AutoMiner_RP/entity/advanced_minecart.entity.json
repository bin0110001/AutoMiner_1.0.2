{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "minere:advanced_minecart",
      "min_engine_version": "1.8.0",
      "materials": {
        "default": "minecart"
      },
      "textures": {
        "default": "textures/entity/minere/advanced_minecart"
      },
      "geometry": {
        "default": "geometry.minecart"
      },
      "scripts": {
        "pre_animation": [
          "variable.hurt = query.hurt_time - query.frame_alpha;"
