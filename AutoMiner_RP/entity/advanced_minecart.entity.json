        "animate": ["move"],
        "should_update_effects_offscreen": "1.0",
        "should_update_bones_and_effects_offscreen": "1.0"
      },
      "animations": {
        "move": "animation.minere.advanced_minecart.move"
      },
      "render_controllers": ["controller.render.minecart"]
    }
  }
}
