{
  "format_version": "1.18.20",
  "minecraft:entity": {
    "description": {
      "identifier": "minere:auto_miner",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "minere:fuel": {
          "type": "int",
          "client_sync": true,
          "default": 0,
          "range": [0, 3000]
        },
        "minere:is_on": {
          "type": "bool",
          "client_sync": true,
          "default": false
        },
        "minere:rail_index": {
          "type": "int",
          "client_sync": false,
          "default": 16,
          "range": [0, 63]
        }
      }
    },
    "components": {
      "minecraft:physics": {
        "has_gravity": true,
        "has_collision": true,
        "push_towards_closest_space": true
      },
      "minecraft:knockback_resistance": {
        "value": 1.0
      },
      "minecraft:health": {
        "value": 20
      },
      "minecraft:damage_sensor": {
        "triggers": [
          {
            "cause": "fall",
            "damage_multiplier": 0.05,
            "damage_modifier": -2,
            "on_damage": {
              "event": "minere:turn_off",
              "target": "self"
            }
          },
          {
            "cause": "suffocation",
            "deals_damage": false
          },
          {
            "cause": "fire",
            "deals_damage": false
          },
          {
            "cause": "projectile",
            "on_damage": {
              "event": "minere:turn_off",
              "target": "self"
            }
          },
          {
            "cause": "entity_attack",
            "on_damage": {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "operator": "==",
                "value": "player"
              },
              "event": "minere:toggle_on",
              "target": "self"
            }
          }
        ]
      },
      "minecraft:fire_immune": {},
      "minecraft:inventory": {
        "container_type": "inventory",
        "inventory_size": 27,
        "can_be_siphoned_from": true
      },
      "minecraft:collision_box": {
        "width": 1.25,
        "height": 1.25
      },
      "minecraft:pushable": {
        "is_pushable": false
      }
    },
    "events": {
      "minere:refuel_450": {
        "sequence": [
          {
            "set_property": {
              "minere:fuel": "query.property('minere:fuel') + 450"
            }
          },
          {
            "queue_command": {
              "command": "playsound machine.auto_miner.fill @a ~ ~ ~ 5.0"
            }
          },
          {
            "set_property": {
              "minere:is_on": true
            }
          }
        ]
      },
      "minere:refuel_750": {
        "sequence": [
          {
            "set_property": {
              "minere:fuel": "query.property('minere:fuel') + 750"
            }
          },
          {
            "queue_command": {
              "command": "playsound machine.auto_miner.fill @a ~ ~ ~ 5.0"
            }
          },
          {
            "set_property": {
              "minere:is_on": true
            }
          }
        ]
      },
      "minere:refuel_1250": {
        "sequence": [
          {
            "set_property": {
              "minere:fuel": "query.property('minere:fuel') + 1250"
            }
          },
          {
            "queue_command": {
              "command": "playsound machine.auto_miner.fill @a ~ ~ ~ 5.0"
            }
          },
          {
            "set_property": {
              "minere:is_on": true
            }
          }
        ]
      },
      "minere:refuel_3000": {
        "sequence": [
          {
            "set_property": {
              "minere:fuel": "query.property('minere:fuel') + 3000"
            }
          },
          {
            "queue_command": {
              "command": "playsound machine.auto_miner.fill @a ~ ~ ~ 5.0"
            }
          },
          {
            "set_property": {
              "minere:is_on": true
            }
          }
        ]
      },
      "minere:turn_on": {
        "filters": {
          "test": "actor_health",
          "operator": ">",
          "value": 0,
          "subject": "self"
        },
        "set_property": {
          "minere:is_on": true
        }
      },
      "minere:turn_off": {
        "set_property": {
          "minere:is_on": false
        }
      },
      "minere:toggle_on": {
        "filters": {
          "test": "actor_health",
          "operator": ">",
          "value": 0,
          "subject": "self"
        },
        "set_property": {
          "minere:is_on": "!query.property('minere:is_on')"
        }
      }
    }
  }
}